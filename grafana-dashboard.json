    {
      "id": 17,
      "title": "Recent Spans",
      "type": "table",
      "datasource": {
        "type": "vertamedia-clickhouse-datasource",
        "uid": "dfl08clqvqarkd"
      },
      "gridPos": {
        "x": 0,
        "y": 43,
        "w": 24,
        "h": 14
      },
      "targets": [
        {
          "datasource": {
            "type": "vertamedia-clickhouse-datasource",
            "uid": "dfl08clqvqarkd"
          },
          "format": "table",
          "query": "SELECT TraceId, SpanName, ServiceName, round(Duration / 1000000, 2) AS DurationMs, StatusCode, SpanAttributes['llm.request.model'] AS Model, SpanAttributes['user.name'] AS User, if(SpanAttributes['llm.output.tokens'] != '', toUInt32(SpanAttributes['llm.output.tokens']), 0) AS OutputTokens, if(SpanAttributes['llm.input.tokens'] != '', toUInt32(SpanAttributes['llm.input.tokens']), 0) AS InputTokens, if(SpanAttributes['llm.cache.read_tokens'] != '', toUInt32(SpanAttributes['llm.cache.read_tokens']), 0) AS CacheRead, if(SpanAttributes['llm.cache.write_tokens'] != '', toUInt32(SpanAttributes['llm.cache.write_tokens']), 0) AS CacheWrite, if(SpanAttributes['llm.output.tokens'] != '', round(1000.0 * toFloat64(SpanAttributes['llm.output.tokens']) / Duration, 1), 0) AS TokensPerSec, toDateTime64(Timestamp, 3) AS StartedAt FROM otel.otel_traces ORDER BY Timestamp DESC LIMIT 200",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "StatusCode"
            },
            "properties": [
              {
                "id": "color",
                "mode": "thresholds"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    }
                  ]
                }
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "Error": {
                        "color": "red",
                        "text": "Error"
